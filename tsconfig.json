{
  "compilerOptions": {
    "target": "ES2020",
    // Using ES2020 modules for modern import/export compatibility
    "module": "ES2020",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "strict": true,
    "types": ["node", "playwright/test"]
  },
  "include": ["tests/**/*.ts", "playwright.config.ts", "test_data/**/*.ts"]
}